# ============================================================
# AI Tutor Platform — Root .gitignore
# ============================================================

# ------------------------------------------------------------
# OS Files
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db

# ------------------------------------------------------------
# IDE & Editor
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ------------------------------------------------------------
# Spec / Design Documents (large binary files)
# ------------------------------------------------------------
*.docx
*.doc
*.pptx
*.ppt
*.xlsx
*.xls

# ------------------------------------------------------------
# Secrets & Credentials
# ------------------------------------------------------------
.env.local
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ------------------------------------------------------------
# Log Files
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Claude Code / AI assistant files
# ------------------------------------------------------------
.claude/
memory/

# ------------------------------------------------------------
# Linting / formatting caches
# ------------------------------------------------------------
.ruff_cache/

# ------------------------------------------------------------
# Legacy agent versions (v1 & v2) — kept locally for reference only
# Only agents_v3 (the DeepAgent) ships in the repository
# ------------------------------------------------------------
backend/app/agents/
backend/app/agents_v2/

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.bak
*.tmp
*.temp
TEST_RESULTS.md

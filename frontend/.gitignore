# ============================================================
# AI Tutor Platform — Frontend .gitignore (React / TypeScript / Vite)
# ============================================================

# ------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# ------------------------------------------------------------
# Build Output
# ------------------------------------------------------------
dist/
dist-ssr/
build/
out/

# ------------------------------------------------------------
# Vite & Tooling Cache
# ------------------------------------------------------------
.vite/
.cache/
.parcel-cache/

# ------------------------------------------------------------
# Test Coverage
# ------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------
# Environment Variables
# NOTE: .env.example is intentionally NOT ignored
# ------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
.env.*.local
*.local

# ------------------------------------------------------------
# TypeScript
# ------------------------------------------------------------
*.tsbuildinfo

# ------------------------------------------------------------
# Linting & Formatting Cache
# ------------------------------------------------------------
.eslintcache
.stylelintcache
.prettiercache

# ------------------------------------------------------------
# Storybook
# ------------------------------------------------------------
storybook-static/

# ------------------------------------------------------------
# Log Files
# ------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------
# OS Files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Editor / IDE (local overrides — root .gitignore covers dirs)
# ------------------------------------------------------------
*.swp
*.swo

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.bak
*.tmp

# ============================================================
# AI Tutor Platform — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
JSON_LOGS=true               # true for structured JSON output; false for dev console

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-256-bit-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Hugging Face ──────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_token_here  # Required — get from https://huggingface.co/settings/tokens

# ── MongoDB (primary datastore + eval storage) ────────────────────────────────
MONGO_URL=mongodb://localhost:27017           # Atlas: mongodb+srv://user:pass@cluster/
MONGO_DATABASE=ai_tutor
MONGO_COLLECTION_EVALS=agent_evals

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Langfuse Tracing (leave empty to disable) ────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── OpenTelemetry (leave empty to disable OTLP export) ───────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=         # e.g. http://localhost:4318 or your Grafana Cloud URL
OTEL_SERVICE_NAME=ai-tutor
OTEL_ENABLED=true

# ── Resilience tunables ───────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3         # Max retries on transient HF errors
RETRY_BASE_DELAY_S=1.0       # Base delay for exponential backoff (seconds)
RETRY_MAX_DELAY_S=16.0       # Cap on backoff delay (seconds)
CB_FAILURE_THRESHOLD=5       # Circuit opens after this many failures in CB_WINDOW_S
CB_WINDOW_S=60               # Sliding window for failure counting (seconds)
CB_RECOVERY_S=30             # How long circuit stays open before half-open probe (seconds)

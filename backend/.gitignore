# ============================================================
# AI Tutor Platform — Backend .gitignore (Python / FastAPI)
# ============================================================

# ------------------------------------------------------------
# Python Bytecode & Compiled Extensions
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ------------------------------------------------------------
# Python Distribution / Packaging
# ------------------------------------------------------------
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# ------------------------------------------------------------
# Environment Variables
# NOTE: .env.example is intentionally NOT ignored
# ------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
.env.*.local

# ------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover

# ------------------------------------------------------------
# Type Checking
# ------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ------------------------------------------------------------
# Linting Cache
# ------------------------------------------------------------
.ruff_cache/

# ------------------------------------------------------------
# Log Files
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# ------------------------------------------------------------
# Alembic (keep migration scripts, ignore compiled artifacts)
# ------------------------------------------------------------
alembic/versions/*.pyc

# ------------------------------------------------------------
# Celery
# ------------------------------------------------------------
celerybeat-schedule
celerybeat.pid

# ------------------------------------------------------------
# Jupyter Notebooks (checkpoint artifacts)
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints/

# ------------------------------------------------------------
# Secrets & Certificates
# ------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ------------------------------------------------------------
# Docker (local overrides — don't ignore the committed Dockerfiles)
# ------------------------------------------------------------
.docker/

# ------------------------------------------------------------
# OS Files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Editor / IDE (local overrides)
# ------------------------------------------------------------
*.swp
*.swo

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.bak
*.tmp

# DeepEval local telemetry/cache
.deepeval/
.deepeval_telemetry.txt

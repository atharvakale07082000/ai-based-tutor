[MASTER]
# Folders to skip entirely (relative to the directory pylint is invoked from)
ignore=migrations,venv,.venv,__pycache__,alembic

# Show a quality score at the end of each run
score=yes

[MESSAGES CONTROL]
disable=
    # ── Docstrings (covered by ruff D rules if we ever enable them) ──────────
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring

    # ── Design / refactoring (ruff handles these; pylint is too strict) ──────
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    R0914,  # too-many-locals
    R0917,  # too-many-positional-arguments
    R0911,  # too-many-return-statements
    R0912,  # too-many-branches (chat orchestrator has complex routing logic)
    R0915,  # too-many-statements (large async handler functions)
    R0801,  # duplicate-code (similar HF client patterns across agents)
    R1713,  # consider-using-join (cosmetic)
    R0401,  # cyclic-import (pre-existing in database.py <-> models)

    # ── Style (all handled by ruff) ──────────────────────────────────────────
    C0301,  # line-too-long (enforced by ruff / max-line-length)
    C0302,  # too-many-lines
    C0103,  # invalid-name (ruff handles naming; we have intentional short names)
    C0104,  # disallowed-name (e.g. "bar" in progress bars)
    W0212,  # protected-access (legitimate in agent internals)
    W0613,  # unused-argument (common in async handlers and mocks)
    W0621,  # redefined-outer-name (pytest fixture pattern)
    W0718,  # broad-exception-caught (intentional in resilience wrappers)
    W0707,  # raise-missing-from (style preference, not a bug)

    # ── Imports ──────────────────────────────────────────────────────────────
    C0415,  # import-not-at-top (lazy imports are intentional in agent nodes)
    W0611,  # unused-import (database.py imports models for SQLAlchemy side effects)

    # ── Naming / builtins ────────────────────────────────────────────────────
    W0622,  # redefined-builtin (eval functions conventionally use `input` param)

    # ── Singletons & globals ─────────────────────────────────────────────────
    W0603,  # global-statement (intentional singleton pattern: tracer, mongo client)

    # ── Misc ─────────────────────────────────────────────────────────────────
    W0201   # attribute-defined-outside-init (BaseAgent sets _current_context per-request)

[FORMAT]
max-line-length=120

[BASIC]
# Short variable names that are always acceptable
good-names=i,j,k,ex,Run,_,e,db,lf,id

[TYPECHECK]
# Packages that pylint cannot statically analyse (C extensions / stubs-only)
ignored-modules=
    pymongo,
    motor,
    bson,
    langfuse,
    huggingface_hub,
    socketio,
    celery,
    redis,
    langgraph,
    langchain,
    langchain_core,
    opentelemetry,
    jose,
    bcrypt,
    structlog,
    tenacity,
    ddgs,
    numpy
